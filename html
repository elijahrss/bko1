<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DASA | Medicina Nuclear</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Rajdhani:wght@300;400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #050505;
    --dark: #0d0d0d;
    --dark2: #111111;
    --dark3: #1a1a1a;
    --gray: #2a2a2a;
    --gray2: #3d3d3d;
    --gray3: #6b6b6b;
    --white: #f5f5f5;
    --white2: #e0e0e0;
    --cyan: #00e5ff;
    --cyan2: #00b4cc;
    --cyan3: #007a8c;
    --cyan-glow: rgba(0,229,255,0.15);
    --red: #ff1744;
    --red2: #cc0033;
    --red-glow: rgba(255,23,68,0.15);
    --font-head: 'Orbitron', monospace;
    --font-body: 'Rajdhani', sans-serif;
    --font-mono: 'Share Tech Mono', monospace;
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* ─── SCROLLBAR ─── */
  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: var(--dark); }
  ::-webkit-scrollbar-thumb { background: var(--cyan2); border-radius: 10px; }

  /* ─── CURSOR ─── */
  .cursor {
    width: 12px; height: 12px;
    border-radius: 50%;
    background: var(--cyan);
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    transition: transform 0.1s, opacity 0.3s;
    box-shadow: 0 0 15px var(--cyan);
  }
  .cursor-ring {
    width: 36px; height: 36px;
    border: 1px solid var(--cyan);
    border-radius: 50%;
    position: fixed;
    pointer-events: none;
    z-index: 9998;
    transition: transform 0.15s ease, width 0.3s, height 0.3s;
    opacity: 0.6;
  }

  /* ─── NAV ─── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    background: rgba(5,5,5,0.92);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(0,229,255,0.1);
    padding: 0 40px;
    display: flex; align-items: center; justify-content: space-between;
    height: 64px;
  }
  .nav-logo {
    font-family: var(--font-head);
    font-size: 13px;
    font-weight: 700;
    color: var(--cyan);
    letter-spacing: 4px;
    text-decoration: none;
  }
  .nav-logo span { color: var(--red); }
  .nav-links { display: flex; gap: 32px; list-style: none; }
  .nav-links a {
    color: var(--gray3);
    text-decoration: none;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: color 0.2s;
    font-family: var(--font-head);
  }
  .nav-links a:hover { color: var(--cyan); }
  .nav-badge {
    background: var(--red);
    color: white;
    font-size: 10px;
    font-weight: 700;
    padding: 4px 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-family: var(--font-head);
  }

  /* ─── HERO ─── */
  #hero {
    min-height: 100vh;
    position: relative;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
    padding-top: 64px;
  }
  #hero-canvas { position: absolute; inset: 0; }
  .hero-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(0,229,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,255,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    animation: gridDrift 20s linear infinite;
  }
  @keyframes gridDrift { 0% { transform: translate(0,0); } 100% { transform: translate(60px,60px); } }

  .hero-content {
    position: relative; z-index: 2;
    text-align: center;
    padding: 40px 20px;
  }
  .hero-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--cyan);
    letter-spacing: 4px;
    border: 1px solid var(--cyan3);
    padding: 6px 20px;
    margin-bottom: 32px;
    background: rgba(0,229,255,0.05);
    animation: fadeDown 1s ease both;
  }
  .hero-title {
    font-family: var(--font-head);
    font-size: clamp(42px, 9vw, 100px);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -2px;
    margin-bottom: 16px;
    animation: fadeUp 1s 0.2s ease both;
  }
  .hero-title .line1 { color: var(--white); display: block; }
  .hero-title .line2 {
    color: transparent;
    -webkit-text-stroke: 1px var(--cyan);
    display: block;
    animation: glitch 4s infinite;
  }
  @keyframes glitch {
    0%,95%,100% { text-shadow: none; transform: translate(0,0); }
    96% { text-shadow: -2px 0 var(--red); transform: translate(2px,0); }
    97% { text-shadow: 2px 0 var(--cyan); transform: translate(-2px,0); }
    98% { text-shadow: -2px 0 var(--red); transform: translate(0,0); }
  }
  .hero-sub {
    font-size: clamp(14px, 2vw, 18px);
    color: var(--gray3);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 48px;
    animation: fadeUp 1s 0.4s ease both;
  }
  .hero-stats {
    display: flex; gap: 48px; justify-content: center; flex-wrap: wrap;
    margin-bottom: 56px;
    animation: fadeUp 1s 0.6s ease both;
  }
  .stat-item { text-align: center; }
  .stat-num {
    font-family: var(--font-head);
    font-size: 36px;
    font-weight: 900;
    color: var(--cyan);
    display: block;
    line-height: 1;
  }
  .stat-num.red { color: var(--red); }
  .stat-label {
    font-size: 11px;
    color: var(--gray3);
    letter-spacing: 2px;
    text-transform: uppercase;
    display: block;
    margin-top: 4px;
  }
  .hero-btns {
    display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;
    animation: fadeUp 1s 0.8s ease both;
  }
  .btn-primary {
    background: var(--cyan);
    color: var(--black);
    padding: 14px 36px;
    font-family: var(--font-head);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    border: none; cursor: pointer;
    text-decoration: none;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }
  .btn-primary::after {
    content: '';
    position: absolute; inset: 0;
    background: rgba(255,255,255,0.2);
    transform: translateX(-100%);
    transition: transform 0.3s;
  }
  .btn-primary:hover::after { transform: translateX(0); }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 40px rgba(0,229,255,0.4); }
  .btn-outline {
    background: transparent;
    color: var(--red);
    padding: 14px 36px;
    font-family: var(--font-head);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    border: 1px solid var(--red);
    cursor: pointer;
    text-decoration: none;
    transition: all 0.3s;
  }
  .btn-outline:hover {
    background: var(--red);
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 10px 40px rgba(255,23,68,0.4);
  }

  .scroll-indicator {
    position: absolute; bottom: 32px; left: 50%;
    transform: translateX(-50%);
    animation: bounce 2s infinite;
    color: var(--gray3);
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    display: flex; flex-direction: column; align-items: center; gap: 8px;
  }
  .scroll-line {
    width: 1px; height: 40px;
    background: linear-gradient(to bottom, var(--cyan), transparent);
    animation: extend 2s infinite;
  }
  @keyframes bounce { 0%,100% { transform: translateX(-50%) translateY(0); } 50% { transform: translateX(-50%) translateY(8px); } }
  @keyframes extend { 0%,100% { height: 40px; } 50% { height: 60px; } }
  @keyframes fadeDown { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }

  /* ─── SECTION BASE ─── */
  section { padding: 100px 40px; max-width: 1300px; margin: 0 auto; }
  .section-full { max-width: 100%; padding-left: 0; padding-right: 0; }
  .section-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--cyan);
    letter-spacing: 4px;
    text-transform: uppercase;
    margin-bottom: 12px;
    display: block;
  }
  .section-title {
    font-family: var(--font-head);
    font-size: clamp(28px, 5vw, 52px);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -1px;
    margin-bottom: 24px;
  }
  .section-title span { color: var(--cyan); }
  .section-title .red { color: var(--red); }
  .section-desc {
    color: var(--gray3);
    font-size: 17px;
    line-height: 1.7;
    max-width: 640px;
    margin-bottom: 64px;
  }
  .divider {
    height: 1px;
    background: linear-gradient(to right, transparent, var(--cyan3), transparent);
    margin: 0;
    opacity: 0.4;
  }

  /* ─── O QUE É MEDICINA NUCLEAR ─── */
  #intro { padding-top: 120px; }
  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  .intro-visual {
    position: relative;
    height: 480px;
  }
  .atom-container {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
  }
  .atom-nucleus {
    width: 80px; height: 80px;
    background: radial-gradient(circle, var(--cyan), var(--cyan2));
    border-radius: 50%;
    box-shadow: 0 0 60px var(--cyan), 0 0 120px rgba(0,229,255,0.3);
    animation: pulse 2s ease-in-out infinite;
    position: relative; z-index: 3;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-head);
    font-size: 11px;
    font-weight: 700;
    color: var(--black);
    letter-spacing: 1px;
  }
  @keyframes pulse { 0%,100% { transform: scale(1); box-shadow: 0 0 60px var(--cyan); } 50% { transform: scale(1.1); box-shadow: 0 0 100px var(--cyan), 0 0 200px rgba(0,229,255,0.3); } }
  .orbit {
    position: absolute;
    border: 1px solid rgba(0,229,255,0.3);
    border-radius: 50%;
    left: 50%; top: 50%;
    transform-origin: center center;
  }
  .orbit-1 {
    width: 180px; height: 100px;
    margin-left: -90px; margin-top: -50px;
    animation: orbit1 3s linear infinite;
    transform: rotateX(75deg);
  }
  .orbit-2 {
    width: 260px; height: 140px;
    margin-left: -130px; margin-top: -70px;
    animation: orbit2 4.5s linear infinite;
    transform: rotateX(75deg) rotateY(60deg);
  }
  .orbit-3 {
    width: 340px; height: 200px;
    margin-left: -170px; margin-top: -100px;
    animation: orbit3 6s linear infinite;
    transform: rotateX(75deg) rotateY(120deg);
  }
  @keyframes orbit1 { from { transform: rotateX(75deg) rotateZ(0deg); } to { transform: rotateX(75deg) rotateZ(360deg); } }
  @keyframes orbit2 { from { transform: rotateX(75deg) rotateY(60deg) rotateZ(0deg); } to { transform: rotateX(75deg) rotateY(60deg) rotateZ(-360deg); } }
  @keyframes orbit3 { from { transform: rotateX(75deg) rotateY(120deg) rotateZ(0deg); } to { transform: rotateX(75deg) rotateY(120deg) rotateZ(360deg); } }
  .orbit-dot {
    width: 10px; height: 10px;
    background: var(--red);
    border-radius: 50%;
    position: absolute;
    top: -5px; left: 50%;
    margin-left: -5px;
    box-shadow: 0 0 10px var(--red);
  }

  .info-cards {
    display: flex; flex-direction: column; gap: 16px;
  }
  .info-card {
    background: var(--dark2);
    border: 1px solid var(--gray);
    padding: 24px 28px;
    position: relative;
    overflow: hidden;
    transition: all 0.4s;
    cursor: default;
  }
  .info-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--cyan);
    transform: scaleY(0);
    transition: transform 0.3s;
    transform-origin: bottom;
  }
  .info-card:hover::before { transform: scaleY(1); }
  .info-card:hover {
    background: var(--dark3);
    border-color: var(--cyan3);
    transform: translateX(6px);
  }
  .info-card-num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--cyan);
    letter-spacing: 2px;
    margin-bottom: 8px;
  }
  .info-card h3 {
    font-family: var(--font-head);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 1px;
    color: var(--white);
    margin-bottom: 6px;
  }
  .info-card p { font-size: 14px; color: var(--gray3); line-height: 1.6; }

  /* ─── EXAMES CARDS ─── */
  #exames { padding: 100px 40px; max-width: 1300px; margin: 0 auto; }
  .exames-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2px;
    margin-top: 64px;
  }
  .exam-card {
    background: var(--dark2);
    padding: 48px 36px;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    border: 1px solid transparent;
  }
  .exam-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--cyan-glow), transparent);
    opacity: 0;
    transition: opacity 0.5s;
  }
  .exam-card:hover::after { opacity: 1; }
  .exam-card:hover {
    border-color: var(--cyan3);
    transform: translateY(-8px);
    z-index: 2;
    box-shadow: 0 30px 80px rgba(0,0,0,0.6), 0 0 60px rgba(0,229,255,0.1);
  }
  .exam-card.red-card:hover::after {
    background: linear-gradient(135deg, var(--red-glow), transparent);
  }
  .exam-card.red-card:hover { border-color: var(--red2); box-shadow: 0 30px 80px rgba(0,0,0,0.6), 0 0 60px rgba(255,23,68,0.1); }
  .exam-icon {
    font-size: 48px;
    margin-bottom: 24px;
    display: block;
    position: relative; z-index: 1;
    transition: transform 0.5s;
    filter: drop-shadow(0 0 10px var(--cyan));
  }
  .exam-card.red-card .exam-icon { filter: drop-shadow(0 0 10px var(--red)); }
  .exam-card:hover .exam-icon { transform: scale(1.15) rotate(-5deg); }
  .exam-card h3 {
    font-family: var(--font-head);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 1px;
    color: var(--white);
    margin-bottom: 12px;
    position: relative; z-index: 1;
  }
  .exam-card p {
    font-size: 14px;
    color: var(--gray3);
    line-height: 1.7;
    position: relative; z-index: 1;
    margin-bottom: 20px;
  }
  .exam-card .learn-more {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--cyan);
    letter-spacing: 2px;
    text-transform: uppercase;
    display: flex; align-items: center; gap: 8px;
    transition: gap 0.3s;
    position: relative; z-index: 1;
    cursor: pointer;
    border: none; background: none;
  }
  .exam-card.red-card .learn-more { color: var(--red); }
  .exam-card:hover .learn-more { gap: 16px; }
  .exam-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 3px 10px;
    letter-spacing: 2px;
    margin-bottom: 16px;
    position: relative; z-index: 1;
  }
  .tag-cyan { background: rgba(0,229,255,0.1); color: var(--cyan); border: 1px solid var(--cyan3); }
  .tag-red { background: rgba(255,23,68,0.1); color: var(--red); border: 1px solid var(--red2); }

  /* ─── EXAM MODAL ─── */
  .modal-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.85);
    z-index: 2000;
    display: flex; align-items: center; justify-content: center;
    padding: 20px;
    opacity: 0; pointer-events: none;
    transition: opacity 0.3s;
    backdrop-filter: blur(8px);
  }
  .modal-overlay.active { opacity: 1; pointer-events: all; }
  .modal-box {
    background: var(--dark2);
    border: 1px solid var(--cyan3);
    max-width: 760px; width: 100%;
    max-height: 85vh;
    overflow-y: auto;
    padding: 48px;
    position: relative;
    transform: translateY(30px) scale(0.97);
    transition: transform 0.3s;
  }
  .modal-overlay.active .modal-box { transform: translateY(0) scale(1); }
  .modal-close {
    position: absolute; top: 20px; right: 20px;
    background: none; border: none;
    color: var(--gray3); font-size: 24px; cursor: pointer;
    transition: color 0.2s;
  }
  .modal-close:hover { color: var(--red); }
  .modal-title {
    font-family: var(--font-head);
    font-size: 22px;
    font-weight: 700;
    color: var(--cyan);
    margin-bottom: 8px;
  }
  .modal-content { margin-top: 24px; }
  .modal-content h4 {
    font-family: var(--font-head);
    font-size: 13px;
    color: var(--white);
    letter-spacing: 2px;
    margin: 24px 0 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--gray);
  }
  .modal-content p, .modal-content li {
    color: var(--gray3);
    font-size: 15px;
    line-height: 1.8;
    margin-bottom: 8px;
  }
  .modal-content ul { padding-left: 20px; }
  .modal-content .alert {
    background: rgba(255,23,68,0.08);
    border-left: 3px solid var(--red);
    padding: 16px 20px;
    margin: 16px 0;
    font-size: 14px;
    color: var(--white2);
  }
  .modal-content .tip {
    background: rgba(0,229,255,0.06);
    border-left: 3px solid var(--cyan);
    padding: 16px 20px;
    margin: 16px 0;
    font-size: 14px;
    color: var(--white2);
  }

  /* ─── CONTRASTE SECTION ─── */
  #contraste {
    background: var(--dark2);
    padding: 100px 40px;
    max-width: 100%;
    border-top: 1px solid var(--gray);
    border-bottom: 1px solid var(--gray);
  }
  #contraste > div { max-width: 1300px; margin: 0 auto; }
  .contraste-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
    margin-top: 64px;
  }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 24px;
  }
  .compare-table th {
    background: var(--gray);
    color: var(--cyan);
    font-family: var(--font-head);
    font-size: 11px;
    letter-spacing: 2px;
    padding: 14px 20px;
    text-align: left;
  }
  .compare-table td {
    padding: 14px 20px;
    border-bottom: 1px solid var(--gray);
    font-size: 14px;
    color: var(--gray3);
  }
  .compare-table tr:hover td { background: rgba(0,229,255,0.03); color: var(--white2); }
  .compare-table .tag-sp { color: var(--cyan); font-weight: 600; }
  .compare-table .tag-rj { color: var(--red); font-weight: 600; }

  .triagem-steps {
    display: flex; flex-direction: column; gap: 0;
  }
  .triagem-step {
    display: flex; gap: 24px; align-items: flex-start;
    padding: 24px 0;
    border-bottom: 1px solid var(--gray);
    cursor: pointer;
    transition: all 0.3s;
  }
  .triagem-step:hover { padding-left: 12px; }
  .step-num {
    font-family: var(--font-head);
    font-size: 24px;
    font-weight: 900;
    color: var(--gray2);
    min-width: 40px;
    line-height: 1;
    transition: color 0.3s;
  }
  .triagem-step:hover .step-num { color: var(--cyan); }
  .step-content h4 {
    font-family: var(--font-head);
    font-size: 13px;
    color: var(--white);
    letter-spacing: 1px;
    margin-bottom: 6px;
  }
  .step-content p { font-size: 14px; color: var(--gray3); line-height: 1.6; }
  .step-badge {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 3px 10px;
    letter-spacing: 1px;
    white-space: nowrap;
  }

  /* ─── CINTILOGRAFIA ─── */
  #cintilografia { max-width: 1300px; margin: 0 auto; padding: 100px 40px; }
  .cintil-tabs {
    display: flex; gap: 0;
    border-bottom: 1px solid var(--gray);
    margin: 40px 0 0;
    overflow-x: auto;
  }
  .cintil-tab {
    font-family: var(--font-head);
    font-size: 11px;
    letter-spacing: 2px;
    padding: 16px 28px;
    cursor: pointer;
    color: var(--gray3);
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: all 0.3s;
    background: none;
    border-top: none; border-left: none; border-right: none;
  }
  .cintil-tab.active {
    color: var(--cyan);
    border-bottom-color: var(--cyan);
  }
  .cintil-tab:hover { color: var(--white2); }
  .cintil-panels { margin-top: 48px; }
  .cintil-panel { display: none; }
  .cintil-panel.active { display: block; animation: fadeIn 0.4s ease; }
