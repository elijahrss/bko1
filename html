let currentQ = 0, score = 0, answered = false;
function initQuiz() {
  currentQ = 0; score = 0; answered = false;
  document.getElementById('quiz-main').style.display = 'block';
  document.getElementById('quiz-score').style.display = 'none';
  renderQuestion();
}
function renderQuestion() {
  answered = false;
  const q = questions[currentQ];
  const prog = document.getElementById('quiz-progress');
  prog.innerHTML = questions.map((_, i) => `<div class="qp-bar ${i < currentQ ? 'done' : i === currentQ ? 'current' : ''}"></div>`).join('');
  document.getElementById('q-text').textContent = q.q;
  const letters = ['A', 'B', 'C', 'D'];
  document.getElementById('q-options').innerHTML = q.opts.map((o, i) =>
    `<div class="quiz-opt" onclick="selectOpt(${i})" id="opt-${i}"><span class="opt-letter">${letters[i]}</span>${o}</div>`
  ).join('');
  document.getElementById('q-feedback').style.display = 'none';
  document.getElementById('quiz-next').style.display = 'none';
}
function selectOpt(i) {
  if (answered) return;
  answered = true;
  const q = questions[currentQ];
  const fb = document.getElementById('q-feedback');
  document.querySelectorAll('.quiz-opt').forEach(o => o.classList.add('disabled'));
  if (i === q.correct) {
    document.getElementById('opt-' + i).classList.add('correct');
    fb.className = 'quiz-feedback correct';
    fb.textContent = '✓ ' + q.exp;
    score++;
  } else {
    document.getElementById('opt-' + i).classList.add('wrong');
    document.getElementById('opt-' + q.correct).classList.add('correct');
    fb.className = 'quiz-feedback wrong';
    fb.textContent = '✗ ' + q.exp;
  }
  fb.style.display = 'block';
  document.getElementById('quiz-next').style.display = 'block';
  document.getElementById('quiz-next').textContent = currentQ < questions.length - 1 ? 'PRÓXIMA PERGUNTA →' : 'VER RESULTADO →';
}
function nextQuestion() {
  currentQ++;
  if (currentQ < questions.length) { renderQuestion(); }
  else {
    document.getElementById('quiz-main').style.display = 'none';
    const s = document.getElementById('quiz-score');
    s.style.display = 'block';
    document.getElementById('score-display').textContent = score + '/' + questions.length;
    const msgs = ['Continue estudando!', 'Bom progresso!', 'Muito bom!', 'Ótimo resultado!', 'Perfeito = expert em Medicina Nuclear!'];
    document.getElementById('score-msg').textContent = msgs[score] || msgs[4];
  }
}
function restartQuiz() { initQuiz(); }
